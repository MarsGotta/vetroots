# ============================================
# Vetroots — Environment Variables
# Copy to .env and fill in values
# ============================================

# --- Strapi CMS ---
HOST=0.0.0.0
PORT=1337
APP_KEYS=toBeGenerated1,toBeGenerated2,toBeGenerated3,toBeGenerated4
API_TOKEN_SALT=toBeGenerated
ADMIN_JWT_SECRET=toBeGenerated
TRANSFER_TOKEN_SALT=toBeGenerated
JWT_SECRET=toBeGenerated

# --- Database (PostgreSQL) ---
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=vetroots
DATABASE_USERNAME=vetroots
DATABASE_PASSWORD=vetroots_dev
DATABASE_SSL=false

# --- Cloudflare R2 (S3-compatible media storage) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=vetroots-media
R2_PUBLIC_DOMAIN=media.vetroots.com

# --- Meilisearch ---
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_MASTER_KEY=dev_master_key_change_in_production
MEILISEARCH_SEARCH_KEY=

# --- Next.js Frontend ---
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_R2_PUBLIC_URL=https://media.vetroots.com
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=
REVALIDATION_SECRET=toBeGenerated

# ============================================
# Production Deployment Notes
# ============================================
#
# STRAPI (Docker):
#   Use docker/docker-compose.prod.yml
#   Generate all secrets: APP_KEYS (4 comma-separated), API_TOKEN_SALT,
#   ADMIN_JWT_SECRET, TRANSFER_TOKEN_SALT, JWT_SECRET
#   Generate: openssl rand -base64 32
#   Set DATABASE_SSL=true if using managed PostgreSQL
#
# MEILISEARCH:
#   Generate strong MEILISEARCH_MASTER_KEY (32+ chars)
#   After first boot, retrieve the default search API key from:
#     GET /keys?limit=10 (with master key)
#   Set MEILISEARCH_SEARCH_KEY to the "Default Search API Key" value
#
# NEXT.JS (Vercel):
#   Set NEXT_PUBLIC_STRAPI_URL to production Strapi URL (e.g. https://cms.vetroots.com)
#   Set NEXT_PUBLIC_MEILISEARCH_HOST to production Meilisearch URL
#   Set NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY to public search-only key
#   Set REVALIDATION_SECRET to shared secret between Strapi webhook and Vercel
#
# STRAPI WEBHOOK (ISR):
#   In Strapi Admin > Settings > Webhooks, create:
#     URL: https://vetroots.vercel.app/api/revalidate
#     Events: entry.publish, entry.unpublish, entry.delete
#     Headers: x-webhook-secret: <REVALIDATION_SECRET>
#
# R2:
#   Create bucket in Cloudflare Dashboard
#   Enable public access or custom domain
#   Generate API token with Object Read & Write permissions
