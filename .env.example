# ============================================
# Vetroots — Environment Variables
# Copy to .env and fill in values
# ============================================

# --- Strapi CMS ---
HOST=0.0.0.0
PORT=1337
APP_KEYS=toBeGenerated1,toBeGenerated2,toBeGenerated3,toBeGenerated4
API_TOKEN_SALT=toBeGenerated
ADMIN_JWT_SECRET=toBeGenerated
TRANSFER_TOKEN_SALT=toBeGenerated
JWT_SECRET=toBeGenerated

# --- Database (PostgreSQL) ---
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=vetroots
DATABASE_USERNAME=vetroots
DATABASE_PASSWORD=vetroots_dev
DATABASE_SSL=false

# --- Cloudflare R2 (S3-compatible media storage) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=vetroots-media
R2_PUBLIC_DOMAIN=media.vetroots.com

# --- Meilisearch ---
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_MASTER_KEY=dev_master_key_change_in_production
MEILISEARCH_SEARCH_KEY=

# --- Next.js Frontend ---
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_R2_PUBLIC_URL=https://media.vetroots.com
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=
REVALIDATION_SECRET=toBeGenerated
