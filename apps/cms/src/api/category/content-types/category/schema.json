{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Content category for organizing fichas, posters, and videos"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 100
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text",
      "maxLength": 500
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "order": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "fichas": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ficha.ficha",
      "mappedBy": "category"
    },
    "posters": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::poster.poster",
      "mappedBy": "category"
    },
    "videos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::video.video",
      "mappedBy": "category"
    }
  }
}
